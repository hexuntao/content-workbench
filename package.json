{
  "name": "content-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check package.json tsconfig.json biome.jsonc next.config.ts src",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --env-file=.env --import tsx --test --test-concurrency=1 src/lib/navigation.test.ts src/server/repositories/repositories.test.ts src/features/drafts/server/draft-workbench.test.ts src/features/review/server/review-service.test.ts src/features/publish/server/publish-service.test.ts src/features/topics/server/topics-service.test.ts src/server/services/jobs/job-service.test.ts src/server/workflows/worker.test.ts",
    "format": "biome check --write package.json tsconfig.json biome.jsonc next.config.ts src"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
